PORT=3000

FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Option A: point to a local service account file that is ignored by git.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: paste the full service account JSON as one line instead of using a file.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
